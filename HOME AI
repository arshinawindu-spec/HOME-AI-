<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Homeo AI — Your AI Homeopathy Companion</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<script type="text/javascript">
function googleTranslateElementInit() {
  new google.translate.TranslateElement({
    pageLanguage: 'en',
    includedLanguages: 'hi,bn,ta,te,mr,gu,kn,ml,pa,ur,en',
    layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
    autoDisplay: false
  }, 'google_translate_element');
}
</script>
<script type="text/javascript" src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
<style>
:root {
  --blue: #1B4F8A;
  --blue-dark: #0D2B4E;
  --blue-light: #E6F0FA;
  --teal: #1A8C6A;
  --teal-light: #E0F5EC;
  --amber: #D97706;
  --amber-light: #FEF3C7;
  --red: #DC2626;
  --bg: #F0F4F8;
  --white: #ffffff;
  --text: #0D2B4E;
  --muted: #4A6785;
  --border: #C4D4E8;
  --card: #ffffff;
  --radius: 12px;
  --radius-sm: 8px;
  --radius-pill: 100px;
}

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);font-size:15px;line-height:1.6;min-height:100vh}

/* SCROLLBAR */
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

/* LAYOUT */
.page{display:none}
.page.active{display:block;animation:fadeIn 0.3s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* NAVBAR */
nav{background:var(--blue-dark);position:sticky;top:0;z-index:100;border-bottom:1px solid rgba(255,255,255,0.08)}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 24px;height:60px;display:flex;align-items:center;justify-content:space-between}
.nav-logo{display:flex;align-items:center;gap:10px;cursor:pointer}
.logo-mark{width:34px;height:34px;background:var(--teal);border-radius:10px;display:flex;align-items:center;justify-content:center}
.logo-mark svg{width:18px;height:18px;fill:white}
.logo-text{font-family:'DM Serif Display',serif;font-size:20px;color:white;letter-spacing:-0.3px}
.logo-text span{color:#6FD5B0;font-style:italic}
.nav-tabs{display:flex;gap:2px}
.nav-tab{padding:6px 16px;color:rgba(255,255,255,0.6);font-size:13px;font-weight:500;cursor:pointer;border-radius:var(--radius-sm);border:none;background:none;display:flex;align-items:center;gap:6px;transition:all 0.2s}
.nav-tab:hover{color:white;background:rgba(255,255,255,0.08)}
.nav-tab.active{color:white;background:rgba(255,255,255,0.12)}
.nav-tab svg{width:14px;height:14px;fill:currentColor}
.nav-right{display:flex;align-items:center;gap:10px}
.plan-pill{background:var(--teal);color:white;font-size:11px;font-weight:600;padding:4px 12px;border-radius:var(--radius-pill);letter-spacing:0.3px}
.bell-btn{width:34px;height:34px;border-radius:50%;background:rgba(255,255,255,0.1);border:none;display:flex;align-items:center;justify-content:center;cursor:pointer}
.bell-btn svg{width:15px;height:15px;fill:white}

/* CONTAINER */
.container{max-width:1200px;margin:0 auto;padding:40px 24px}

/* DISCLAIMER */
.disclaimer{border-left:4px solid var(--amber);background:var(--amber-light);padding:14px 18px;border-radius:0 var(--radius-sm) var(--radius-sm) 0;font-size:12px;color:#78350F;line-height:1.6}
.disclaimer strong{display:flex;align-items:center;gap:6px;font-size:12px;color:#92400E;margin-bottom:4px}
.disclaimer.blue-border{border-left-color:var(--blue);background:var(--blue-light);color:var(--blue-dark)}
.disclaimer.blue-border strong{color:var(--blue)}
.disclaimer.collapsible{cursor:pointer}
.disclaimer-body{margin-top:6px}
.disclaimer.collapsed .disclaimer-body{display:none}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:8px;padding:11px 24px;border-radius:var(--radius-sm);border:none;font-size:14px;font-weight:500;cursor:pointer;transition:all 0.2s;font-family:'DM Sans',sans-serif}
.btn-primary{background:var(--teal);color:white}
.btn-primary:hover{background:#157a5c;transform:translateY(-1px)}
.btn-blue{background:var(--blue);color:white}
.btn-blue:hover{background:#163f6e;transform:translateY(-1px)}
.btn-outline{background:white;color:var(--blue);border:1.5px solid var(--blue)}
.btn-outline:hover{background:var(--blue-light)}
.btn-full{width:100%;justify-content:center}
.btn svg{width:16px;height:16px;fill:currentColor}
.btn-sm{padding:7px 14px;font-size:12px}

/* CARDS */
.card{background:var(--card);border-radius:var(--radius);border:1px solid var(--border);padding:20px}
.card-sm{padding:14px}

/* ===== HOME PAGE ===== */
.hero{background:var(--blue-dark);border-radius:16px;padding:52px 48px;color:white;display:grid;grid-template-columns:1fr auto;gap:32px;align-items:center;margin-bottom:28px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;right:-60px;top:-60px;width:300px;height:300px;background:rgba(26,140,106,0.15);border-radius:50%}
.hero::after{content:'';position:absolute;right:60px;bottom:-80px;width:200px;height:200px;background:rgba(27,79,138,0.4);border-radius:50%}
.hero-content{position:relative;z-index:1}
.hero-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(111,213,176,0.2);border:1px solid rgba(111,213,176,0.3);color:#6FD5B0;font-size:11px;font-weight:600;padding:4px 12px;border-radius:var(--radius-pill);margin-bottom:16px;letter-spacing:0.5px}
.hero h1{font-family:'DM Serif Display',serif;font-size:38px;line-height:1.2;margin-bottom:12px;letter-spacing:-0.5px}
.hero h1 em{color:#6FD5B0;font-style:italic}
.hero p{color:rgba(255,255,255,0.75);font-size:15px;margin-bottom:24px;max-width:480px}
.hero-btns{display:flex;gap:10px;flex-wrap:wrap}
.hero-visual{position:relative;z-index:1;display:flex;flex-direction:column;gap:10px;min-width:220px}
.stat-card{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.12);border-radius:var(--radius-sm);padding:14px 18px;backdrop-filter:blur(10px)}
.stat-num{font-family:'DM Serif Display',serif;font-size:28px;color:#6FD5B0}
.stat-label{font-size:11px;color:rgba(255,255,255,0.6);margin-top:2px}

.section-title{font-family:'DM Serif Display',serif;font-size:24px;color:var(--text);margin-bottom:6px}
.section-sub{color:var(--muted);font-size:14px;margin-bottom:24px}

.features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:28px}
.feat-card{background:white;border:1px solid var(--border);border-radius:var(--radius);padding:20px;transition:all 0.2s;cursor:default}
.feat-card:hover{border-color:var(--blue);transform:translateY(-2px)}
.feat-icon{width:40px;height:40px;background:var(--blue-light);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:14px}
.feat-icon svg{width:20px;height:20px;fill:var(--blue)}
.feat-card h3{font-size:14px;font-weight:600;margin-bottom:6px;color:var(--text)}
.feat-card p{font-size:12px;color:var(--muted);line-height:1.6}

/* ===== DIAGNOSE PAGE ===== */
.diag-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px}
.diag-header h1{font-family:'DM Serif Display',serif;font-size:28px}
.step-indicator{display:flex;align-items:center;gap:8px}
.step{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;border:2px solid var(--border);color:var(--muted);background:white;transition:all 0.3s}
.step.active{background:var(--blue);color:white;border-color:var(--blue)}
.step.done{background:var(--teal);color:white;border-color:var(--teal)}
.step-line{width:24px;height:2px;background:var(--border)}

.form-layout{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.form-layout.full-col{grid-template-columns:1fr}
.form-group{margin-bottom:16px}
.form-group label{display:block;font-size:12px;font-weight:600;color:var(--muted);margin-bottom:6px;letter-spacing:0.3px;text-transform:uppercase}
.form-group input,.form-group select,.form-group textarea{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:14px;font-family:'DM Sans',sans-serif;color:var(--text);background:white;outline:none;transition:border-color 0.2s}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--blue)}
.form-group textarea{resize:vertical;min-height:80px}
.unit-toggle{display:flex;border:1.5px solid var(--border);border-radius:var(--radius-sm);overflow:hidden}
.unit-toggle span{flex:1;padding:9px 12px;text-align:center;font-size:13px;cursor:pointer;transition:all 0.2s;color:var(--muted)}
.unit-toggle span.active{background:var(--blue);color:white}
.pill-select{display:flex;gap:6px;flex-wrap:wrap}
.ps-pill{padding:7px 16px;border:1.5px solid var(--border);border-radius:var(--radius-pill);font-size:13px;cursor:pointer;background:white;color:var(--muted);transition:all 0.2s}
.ps-pill.active{background:var(--blue);color:white;border-color:var(--blue)}
.form-section{background:white;border:1px solid var(--border);border-radius:var(--radius);padding:24px;margin-bottom:20px}
.form-section-title{font-size:14px;font-weight:600;color:var(--text);margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--bg);display:flex;align-items:center;gap:8px}
.form-section-title svg{width:16px;height:16px;fill:var(--blue)}

/* CHAT */
.chat-container{background:white;border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;display:flex;flex-direction:column;min-height:500px}
.chat-header{background:var(--blue-dark);padding:14px 20px;display:flex;align-items:center;justify-content:space-between}
.chat-header-info{display:flex;align-items:center;gap:10px}
.chat-ai-avatar{width:32px;height:32px;background:var(--teal);border-radius:50%;display:flex;align-items:center;justify-content:center}
.chat-ai-avatar svg{width:16px;height:16px;fill:white}
.chat-header h3{font-size:14px;color:white;font-weight:500}
.chat-header p{font-size:11px;color:rgba(255,255,255,0.6)}
.msg-limit-badge{background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.8);font-size:11px;padding:4px 10px;border-radius:var(--radius-pill)}
.chat-msgs{flex:1;padding:20px;display:flex;flex-direction:column;gap:16px;overflow-y:auto;background:#F8FAFC}
.msg-row{display:flex;gap:10px;align-items:flex-start}
.msg-row.user{flex-direction:row-reverse}
.msg-avatar{width:30px;height:30px;border-radius:50%;background:var(--teal);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:white}
.msg-avatar.user-av{background:var(--blue)}
.msg-bubble{max-width:72%;padding:12px 16px;border-radius:12px;font-size:13px;line-height:1.6}
.msg-bubble.ai{background:white;border:1px solid var(--border);color:var(--text);border-radius:4px 12px 12px 12px}
.msg-bubble.user{background:var(--blue);color:white;border-radius:12px 4px 12px 12px}
.remedy-cards{display:flex;flex-direction:column;gap:8px;margin-top:10px}
.remedy-card{background:white;border:1.5px solid var(--teal);border-radius:10px;padding:12px 14px}
.remedy-card-name{font-size:13px;font-weight:600;color:var(--blue-dark);display:flex;align-items:center;gap:6px}
.remedy-card-name::before{content:'';width:6px;height:6px;background:var(--teal);border-radius:50%;flex-shrink:0}
.remedy-card-detail{font-size:11px;color:var(--muted);margin-top:4px;line-height:1.6}
.remedy-tag{display:inline-block;background:var(--teal-light);color:var(--teal);font-size:10px;font-weight:600;padding:2px 8px;border-radius:var(--radius-pill);margin-right:4px}
.chat-input-area{padding:14px 16px;border-top:1px solid var(--border);background:white;display:flex;gap:10px}
.chat-input-area input{flex:1;padding:10px 16px;border:1.5px solid var(--border);border-radius:var(--radius-pill);font-size:13px;font-family:'DM Sans',sans-serif;outline:none;color:var(--text)}
.chat-input-area input:focus{border-color:var(--blue)}
.send-btn{width:38px;height:38px;background:var(--teal);border:none;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0}
.send-btn svg{width:16px;height:16px;fill:white}

/* ===== MEDICINES PAGE ===== */
.med-search-bar{width:100%;padding:12px 18px 12px 44px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:14px;font-family:'DM Sans',sans-serif;outline:none;color:var(--text);background:white;margin-bottom:14px;transition:border-color 0.2s}
.med-search-bar:focus{border-color:var(--blue)}
.search-wrap{position:relative;margin-bottom:14px}
.search-wrap svg{position:absolute;left:14px;top:50%;transform:translateY(-50%);width:16px;height:16px;fill:var(--muted)}
.chip-row{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px}
.chip{padding:6px 14px;border:1.5px solid var(--border);border-radius:var(--radius-pill);font-size:12px;font-weight:500;cursor:pointer;background:white;color:var(--muted);transition:all 0.2s}
.chip.active,.chip:hover{background:var(--blue);color:white;border-color:var(--blue)}
.med-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.med-card{background:white;border:1px solid var(--border);border-radius:var(--radius);padding:18px;transition:all 0.2s;cursor:pointer}
.med-card:hover{border-color:var(--blue);transform:translateY(-2px)}
.med-name{font-size:14px;font-weight:600;color:var(--text);margin-bottom:4px}
.med-latin{font-size:11px;color:var(--muted);font-style:italic;margin-bottom:8px}
.med-desc{font-size:12px;color:var(--muted);line-height:1.5;margin-bottom:10px}
.tag-row{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:10px}
.tag{font-size:10px;font-weight:600;padding:3px 9px;border-radius:var(--radius-pill)}
.tag.acute{background:#FEE2E2;color:#991B1B}
.tag.chronic{background:#EDE9FE;color:#5B21B6}
.tag.constitutional{background:#D1FAE5;color:#065F46}
.tag.fever{background:#FEF3C7;color:#92400E}
.tag.digestion{background:#E0F2FE;color:#075985}
.view-detail-btn{font-size:12px;color:var(--blue);background:var(--blue-light);border:none;padding:6px 12px;border-radius:6px;cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:500;width:100%;transition:all 0.2s}
.view-detail-btn:hover{background:var(--blue);color:white}

/* REMEDY DETAIL MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(13,43,78,0.5);z-index:200;display:flex;align-items:center;justify-content:center;padding:20px;animation:fadeIn 0.2s ease}
.modal-box{background:white;border-radius:16px;width:100%;max-width:680px;max-height:85vh;overflow-y:auto;padding:32px}
.modal-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px}
.modal-title{font-family:'DM Serif Display',serif;font-size:26px;color:var(--text)}
.modal-subtitle{font-size:13px;color:var(--muted);font-style:italic}
.close-btn{width:32px;height:32px;border-radius:50%;background:var(--bg);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;color:var(--muted);flex-shrink:0}
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px}
.detail-section{background:var(--bg);border-radius:var(--radius-sm);padding:14px}
.detail-section.full{grid-column:1/-1}
.detail-section h4{font-size:11px;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px}
.detail-section ul{list-style:none;display:flex;flex-direction:column;gap:4px}
.detail-section ul li{font-size:12px;color:var(--muted);display:flex;gap:6px;align-items:flex-start;line-height:1.5}
.detail-section ul li::before{content:'•';color:var(--teal);flex-shrink:0;font-weight:700}
.detail-section p{font-size:12px;color:var(--muted);line-height:1.6}
.potency-chips{display:flex;gap:6px;flex-wrap:wrap;margin-top:4px}
.potency-chip{background:var(--blue-light);color:var(--blue);font-size:11px;font-weight:600;padding:3px 10px;border-radius:var(--radius-pill)}
.source-line{font-size:11px;color:var(--muted);margin-top:16px;padding-top:14px;border-top:1px solid var(--border)}

/* ===== DOCTOR PAGE ===== */
.doc-layout{display:grid;grid-template-columns:280px 1fr;gap:20px}
.doc-sidebar{display:flex;flex-direction:column;gap:12px}
.doctor-profile-card{background:white;border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;cursor:pointer;transition:all 0.2s}
.doctor-profile-card:hover,.doctor-profile-card.active-doc{border-color:var(--blue)}
.doctor-profile-card.active-doc{border-width:2px}
.doc-avatar{width:56px;height:56px;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center;color:white;font-family:'DM Serif Display',serif;font-size:20px;margin:0 auto 10px;border:3px solid var(--blue-light)}
.verified-badge{display:inline-flex;align-items:center;gap:4px;background:var(--teal-light);color:var(--teal);font-size:10px;font-weight:700;padding:3px 10px;border-radius:var(--radius-pill);margin-bottom:8px;letter-spacing:0.3px}
.verified-badge svg{width:10px;height:10px;fill:var(--teal)}
.doc-name{font-size:13px;font-weight:600;color:var(--text)}
.doc-spec{font-size:11px;color:var(--muted);margin-top:3px;line-height:1.5}
.doc-reg{font-size:10px;color:var(--border);margin-top:6px;padding-top:8px;border-top:1px solid var(--bg)}
.doc-main{display:flex;flex-direction:column;gap:16px}
.ask-box{background:white;border:1px solid var(--border);border-radius:var(--radius);padding:20px}
.ask-box h3{font-size:15px;font-weight:600;color:var(--text);margin-bottom:12px;display:flex;align-items:center;gap:8px}
.ask-box h3 svg{width:16px;height:16px;fill:var(--blue)}
.ask-box textarea{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:'DM Sans',sans-serif;color:var(--text);outline:none;resize:none;height:80px;transition:border-color 0.2s}
.ask-box textarea:focus{border-color:var(--blue)}
.ask-box-footer{display:flex;align-items:center;justify-content:space-between;margin-top:10px}
.ask-note{font-size:11px;color:var(--muted)}
.query-card{background:white;border:1px solid var(--border);border-radius:var(--radius);padding:18px}
.query-patient{font-size:11px;color:var(--muted);margin-bottom:6px;display:flex;align-items:center;gap:6px}
.query-patient span{background:var(--bg);padding:2px 8px;border-radius:var(--radius-pill)}
.query-q{font-size:13px;color:var(--text);margin-bottom:10px;line-height:1.5}
.query-ans{background:var(--teal-light);border-left:3px solid var(--teal);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px}
.query-ans-doctor{font-size:11px;font-weight:600;color:var(--teal);margin-bottom:4px}
.query-ans p{font-size:12px;color:#065F46;line-height:1.6}

/* ===== PLANS PAGE ===== */
.current-plan-card{background:var(--blue-dark);border-radius:var(--radius);padding:24px;color:white;margin-bottom:24px;display:grid;grid-template-columns:1fr auto;gap:20px;align-items:center}
.cp-label{font-size:11px;color:rgba(255,255,255,0.5);letter-spacing:0.5px;text-transform:uppercase;margin-bottom:4px}
.cp-plan{font-family:'DM Serif Display',serif;font-size:28px;margin-bottom:4px}
.cp-tagline{font-size:13px;color:rgba(255,255,255,0.7);margin-bottom:14px}
.progress-wrap{display:flex;align-items:center;gap:10px}
.progress-bar{flex:1;background:rgba(255,255,255,0.15);border-radius:4px;height:6px;overflow:hidden}
.progress-fill{background:#6FD5B0;height:100%;border-radius:4px}
.progress-label{font-size:11px;color:rgba(255,255,255,0.6);white-space:nowrap}
.upgrade-nudge{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:var(--radius-sm);padding:16px 20px;text-align:center}
.nudge-text{font-size:13px;color:rgba(255,255,255,0.8);margin-bottom:10px}

.plans-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:20px}
.plan-card{background:white;border:1px solid var(--border);border-radius:var(--radius);padding:24px;position:relative;display:flex;flex-direction:column}
.plan-card.featured{border:2.5px solid var(--blue)}
.popular-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--blue);color:white;font-size:10px;font-weight:700;padding:4px 14px;border-radius:var(--radius-pill);white-space:nowrap;letter-spacing:0.5px}
