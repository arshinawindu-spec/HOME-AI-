}

function sendMsg() {
  const input = document.getElementById('chatInput');
  const txt = input.value.trim();
  if (!txt) return;
  if (msgCount >= MAX_FREE) {
    document.getElementById('paywallOverlay').style.display = 'flex';
    return;
  }
  const msgs = document.getElementById('chatMsgs');
  const userDiv = document.createElement('div');
  userDiv.className = 'msg-row user';
  userDiv.innerHTML = '<div class="chat-ai-avatar msg-avatar user-av">You</div><div class="msg-bubble user">' + txt + '</div>';
  msgs.appendChild(userDiv);
  input.value = '';
  msgCount++;
  updateMsgBadge();
  setTimeout(() => {
    const aiDiv = document.createElement('div');
    aiDiv.className = 'msg-row';
    aiDiv.innerHTML = '<div class="chat-ai-avatar msg-avatar"><svg viewBox="0 0 24 24" width="14" height="14" fill="white"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-4H7l5-8.5v4h3l-5 8.5z"/></svg></div><div class="msg-bubble ai">Thank you for the follow-up. Based on classical Materia Medica, Arsenicum Album 30C is the most appropriate starting point. Observe for 48 hours. If there is no improvement, consult a licensed homeopathic physician for a full constitutional assessment. This is educational guidance only.</div>';
    msgs.appendChild(aiDiv);
    msgs.scrollTop = msgs.scrollHeight;
    if (msgCount >= MAX_FREE) setTimeout(() => { document.getElementById('paywallOverlay').style.display = 'flex'; }, 1000);
  }, 800);
  msgs.scrollTop = msgs.scrollHeight;
}

function updateMsgBadge() {
  const rem = MAX_FREE - msgCount;
  document.getElementById('msgLimitBadge').textContent = rem + ' message' + (rem !== 1 ? 's' : '') + ' remaining (Free)';
}

function renderMeds(data) {
  const grid = document.getElementById('medGrid');
  grid.innerHTML = '';
  data.forEach((r, i) => {
    const tagHTML = r.tags.map(t => `<span class="tag ${t}">${t.charAt(0).toUpperCase()+t.slice(1)}</span>`).join('');
    const card = document.createElement('div');
    card.className = 'med-card';
    card.innerHTML = `<div class="med-name">${r.name}</div><div class="med-latin">${r.latin}</div><div class="med-desc">${r.desc}</div><div class="tag-row">${tagHTML}</div><button class="view-detail-btn" onclick="openModal(${i})">View Full Details</button>`;
    grid.appendChild(card);
  });
}

function filterMeds(val) {
  const filtered = remedyData.filter(r => r.name.toLowerCase().includes(val.toLowerCase()) || r.desc.toLowerCase().includes(val.toLowerCase()) || r.mental.join(' ').toLowerCase().includes(val.toLowerCase()) || r.physical.join(' ').toLowerCase().includes(val.toLowerCase()));
  renderMeds(filtered);
}

function filterByChip(el, cat) {
  document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  if (cat === 'All') { renderMeds(remedyData); return; }
  renderMeds(remedyData.filter(r => r.cats.some(c => c.includes(cat))));
}

function openModal(i) {
  const r = remedyData[i];
  document.getElementById('modalTitle').textContent = r.name;
  document.getElementById('modalSub').textContent = r.latin;
  document.getElementById('modalTags').innerHTML = r.tags.map(t => `<span class="tag ${t}">${t.charAt(0).toUpperCase()+t.slice(1)}</span>`).join('');
  document.getElementById('modalContent').innerHTML = `
    <div class="detail-section"><h4>Key Mental Symptoms</h4><ul>${r.mental.map(m=>`<li>${m}</li>`).join('')}</ul></div>
    <div class="detail-section"><h4>Key Physical Symptoms</h4><ul>${r.physical.map(p=>`<li>${p}</li>`).join('')}</ul></div>
    <div class="detail-section"><h4>Better From</h4><ul>${r.modalities.better.map(b=>`<li>${b}</li>`).join('')}</ul></div>
    <div class="detail-section"><h4>Worse From</h4><ul>${r.modalities.worse.map(w=>`<li>${w}</li>`).join('')}</ul></div>
    <div class="detail-section"><h4>Common Potencies</h4><div class="potency-chips">${r.potencies.map(p=>`<span class="potency-chip">${p}</span>`).join('')}</div></div>
    <div class="detail-section"><h4>Typical Dosage</h4><p>${r.dosage}</p></div>
    <div class="detail-section full"><h4>Related Remedies</h4><div class="potency-chips">${r.related.map(rel=>`<span class="potency-chip" style="background:var(--teal-light);color:var(--teal)">${rel}</span>`).join('')}</div></div>
  `;
  document.getElementById('modalSource').innerHTML = `<strong>Source:</strong> ${r.source}`;
  document.getElementById('remedyModal').style.display = 'flex';
}

function closeModal(e) {
  if (e.target === document.getElementById('remedyModal')) {
    document.getElementById('remedyModal').style.display = 'none';
  }
}

function submitQuestion() {
  const txt = document.getElementById('askInput').value.trim();
  if (!txt) return;
  alert('Your question has been submitted! A verified doctor will reply within 24–48 hours. (Basic/Pro feature)');
  document.getElementById('askInput').value = '';
}

document.querySelectorAll('.pw-plan').forEach(p => {
  p.addEventListener('click', () => {
    document.querySelectorAll('.pw-plan').forEach(x => x.classList.remove('selected'));
    p.classList.add('selected');
  });
});

/* ===== PAYMENT FUNCTIONS ===== */
function openPayment(plan, amount) {
  currentPayPlan = plan;
  currentPayAmount = amount;
  document.getElementById('payPlanName').textContent = plan + ' Plan';
  document.getElementById('payPlanPrice').innerHTML = '₹' + amount + '<span style="font-size:13px;font-family:\'DM Sans\',sans-serif;color:var(--muted)">/mo</span>';
  document.getElementById('payHeaderSub').textContent = 'Homeo AI ' + plan + ' Subscription';
  document.getElementById('payBtnAmount').textContent = '₹' + amount;
  document.getElementById('payForm').style.display = 'block';
  document.getElementById('paySuccess').classList.add('pay-tab-hidden');
  selPayMethod(document.getElementById('pm-card'), 'card');
  document.getElementById('payOverlay').style.display = 'flex';
}

function closePayOverlay(e) {
  if (e.target === document.getElementById('payOverlay')) {
    document.getElementById('payOverlay').style.display = 'none';
  }
}

function selPayMethod(el, method) {
  document.querySelectorAll('.pay-method').forEach(m => m.classList.remove('active'));
  el.classList.add('active');
  currentPayMethod = method;
  ['card','upi','netbank','wallet'].forEach(p => {
    const panel = document.getElementById('panel-' + p);
    if (panel) panel.classList.toggle('pay-tab-hidden', p !== method);
  });
}

function formatCard(input) {
  let val = input.value.replace(/\D/g,'').substring(0,16);
  input.value = val.replace(/(.{4})/g,'$1  ').trim();
}

function formatExpiry(input) {
  let val = input.value.replace(/\D/g,'');
  if (val.length >= 2) val = val.substring(0,2) + ' / ' + val.substring(2,4);
  input.value = val;
}

function verifyUPI() {
  const id = document.getElementById('upiId').value.trim();
  if (!id) { alert('Please enter a UPI ID'); return; }
  alert('UPI ID verified: ' + id + '\nAccount: HOMEO AI User');
}

function selBank(el) {
  document.querySelectorAll('.netbank-grid .bank-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}

function selWallet(el) {
  document.querySelectorAll('.wallet-grid .wallet-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}

function selUPIApp(el) {
  el.closest('div').querySelectorAll('.bank-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}

function processPayment() {
  const btn = document.getElementById('paySubmitBtn');
  btn.textContent = 'Processing...';
  btn.style.opacity = '0.7';
  btn.style.cursor = 'not-allowed';
  setTimeout(() => {
    const txn = 'TXN-HOMEO-' + Math.random().toString(36).substr(2,8).toUpperCase();
    const next = new Date();
    next.setMonth(next.getMonth() + 1);
    const nextStr = next.toLocaleDateString('en-IN', {day:'numeric',month:'long',year:'numeric'});
    document.getElementById('txnId').textContent = txn;
    document.getElementById('nextBill').textContent = nextStr;
    document.getElementById('successPlan').textContent = currentPayPlan + ' — ₹' + currentPayAmount + '/month';
    document.getElementById('paySuccessMsg').textContent = 'Your Homeo AI ' + currentPayPlan + ' subscription is now active! Enjoy ' + (currentPayPlan === 'Pro' ? 'unlimited AI messages, full Materia Medica access, and Doctor Corner.' : '50 AI messages/month, full medicine database, and more.');
    document.getElementById('payForm').style.display = 'none';
    document.getElementById('paySuccess').classList.remove('pay-tab-hidden');
    btn.textContent = 'Pay ₹' + currentPayAmount + ' Securely';
    btn.style.opacity = '1';
    btn.style.cursor = 'pointer';
  }, 2000);
}

renderMeds(remedyData);
</script>
</body>
</html>
